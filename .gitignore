# Combined gitignore for portfolio repo
# Keep docs folder and portfolio site ignore rules
docs/

# OS Files
.DS_Store
Thumbs.db
.env.local

# IDE/Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# Dependencies (if you add any)
node_modules/
venv/
__pycache__/
*.egg-info/

# Build/Temp Files
dist/
build/
*.log

# Local testing
.http-server-cwd

# Document backups
*.bak
*.tmp
